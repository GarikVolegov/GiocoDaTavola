# Difese AI dei bot (Fase C) — opzionale. Copia in `server/.env` e compila.
# Se AI_BASE_URL è vuoto, i bot usano le difese templato (gratis, sempre attive).
#
# Esempio con Ollama in locale (gratis):
#   ollama serve            # avvia Ollama
#   ollama pull gemma3:4b   # scarica il modello (4B = buon compromesso CPU)
#   AI_BASE_URL=http://localhost:11434/v1
#   AI_MODEL=gemma3:4b      # in locale, se hai RAM/GPU, puoi usare gemma3:12b
#
# Su un host senza GPU (es. Railway) tieni AI_BASE_URL vuoto (bot templati),
# oppure puntalo a un servizio Ollama con un modello piccolo (4B/1B).

AI_BASE_URL=
AI_MODEL=gemma3:4b
# AI_API_KEY=   # solo per gateway OpenAI-compatible che richiedono un token
